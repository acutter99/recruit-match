# RecruitMatch Environment Configuration
# Copy this file to .env and fill in your values

# Choose ONE LLM provider (OpenAI or Anthropic)
# Leave both blank to use baseline keyword scoring only

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
